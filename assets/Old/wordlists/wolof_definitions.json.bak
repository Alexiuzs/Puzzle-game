  "jéggalul": "'jéggalul",
  "jéggee": "'jéggee",
  "jéggeegul": "'jéggeegul",
  "jéggi": ". Roof-roppi du fékke ayu boroomam.  . Rootaan jéggi nam ndox.",
  "jekk": "Bakkan jekk na ci xar-kanam, ndaxub gise.",
  "jékk": "'jékk",
