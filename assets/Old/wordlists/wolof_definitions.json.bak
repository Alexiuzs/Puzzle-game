  "jéeri": "'jéeri",
  "jees": "'jees",
  "jeex": "Bési Yàlla yi du (ñu) jeex.",
  "jéex": "'jéex",
  "jeexaatoo": "'jeexaatoo",
  "jeexaay": "'jeexaay",
  "jeexagul": "Àddina weeru koor la ; feek jant sowul, juubu du wees. (,) Dund gu jeexagul, weeru koor la : juubu weesoogu ca. (,,) Koor gu jant sowagul, juubu weesoogu ca.",
  "jeexal": "Fullaay jaay daqaar, (mbaa “ma ñam” jeexal ko). (,) Fullaay jaay daqaar mbaa ma macc jeexal ko.  Fullaay jaay daqaar, mbaa – ma mos – jeexal ko.  Fullaay jaay keccax.",
  "jeexale": "'jeexale",
  "jeexe": ".\tFa bon jeexe, la tàmbalee (di bon).",
  "jeexee": "Bu cooroon jeexee, bët sébbi.",
  "jéexee": "'jéexee",
  "jeexi": "'jeexi",
  "jeexle": "'jeexle",
  "jeexlee": ". Yàqkatub marse bu jeexlee toog.  . Yar sa doom taxul nga bañ ko.  . Yar xaj a gën yar nit.",
  "jeexul": "Bu worma jeexul woon, kon ndox du togg jën.",
  "jeey": ".\tJabar jeey takk tubéy, jëkkër jeey woddu.",
  "jeeya": "'jeeya",
  "jëf": ".\tJanax yu bari duñu gas menn pax.  .\tJàng dey gindi jëme ci jëf.",
  "jëfam": "'jëfam",
  "jëfandikoo": "'jëfandikoo",
  "jëfandikukat": "Ki di def walla ki sàkk 'jëfandiku' (Someone who does...).",
  "jëfati": "'jëfati",
  "jëfe": ". Xam-xam ñeent a koy kulóor : di ko bind, di ko jàngale, di ko waxtaane, mbaa di ko jëfe. (,)",
