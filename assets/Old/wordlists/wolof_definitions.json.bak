  "gisi": "'gisi",
  "gisleen": "'gisleen",
  "gisloo": "'gisloo",
  "gisoo": "Bu daay tàkkee, gisoo bàqaar, am na lu ko téye.",
  "gisoon": "'gisoon",
  "gisu": ".\tFoo gisu yàpp, bakkan a dee.  .\tFoo ko fekk muy fenk nib jant.",
  "gisub": "'gisub",
  "gisug": "'gisug",
  "gisul": ".\tGinaar bu toppee ñii taxani dafa gisul ñii bojj.  .\tGinaar dëgg na doom ja, waaye bañu ko. (,)",
  "gisuleen": "'gisuleen",
  "gisuloo": "'gisuloo",
  "gisuma": ". Mag bu gëmmee, ne, gisuma jant bi, kenn mënu ci dara.  . Mag bu rusee, ne “maa tey”.",
  "gisunu": "Defal boppam 'gisun' walla ne ci (Reflexive/Action on self).",
  "gisuñu": "Defal boppam 'gisuñ' walla ne ci (Reflexive/Action on self).",
  "gisuwul": "'gisuwul",
  "gitiit": "'gitiit",
  "gittax": "Jàpp ci gittax ba for yat.",
  "giy": ".\tGàcce giy palmaan ñey, baxa-segu la.",
  "giyon": "'giyon",
  "goddaas": "'goddaas",
  "godoroŋ": "'godoroŋ",
  "gog": "'gog",
  "goj": ". Kuy reere pann, boo woppee fande. (,,) . Kuy rootaani, seetil boroom goj ak baag.  . Kuy rooteek sendal, doo yóbbum ndox.  . Kuy sàkki ron, ku ko abal kàndaama bañu ko.  . Kuy sàngoo làmmiñ boo noppee rafle.",
  "goji": "'goji",
  "golo": "Àddina njoowaanu golo la, garab gu nekk lay wékku. (,)",
  "gom": "'gom",
  "gomeer": "'gomeer",
  "gomor": "'gomor",
  "gone": "Bés a nga di déwén : boo ko waxee gone, mu foog ne tabaski la.  Xale boo ci ni ba déwén, mu defe ni Tabaskee tax ngay wax.",
  "gonee": ".\tGonee may dëkk, waaye mag a may daan !  .\tGonee nga daan sakkane ca lalu ndeyam.  .\tGoneey doon mag.",
  "goneek": "'goneek",
  "goneem": "'goneem",
  "goneg": ".\tGoneg mbóoyo gu reew, xaar ko ca taatu ndaa la. (,,,) .\tGont taxani for aw ñey, muur a koy maye.",
  "goney": ".\tGone bu téyee ci loxoob baayam, ku mu gis defe ne baayam a la mën.  .\tGone, bu yaroo macc tàngal, yëy goney Ngaayam.",
  "gongo": "'gongo",
  "gonloo": "'gonloo",
  "gont": ".\tGoneg mbóoyo gu reew, xaar ko ca taatu ndaa la. (,,,) .\tGont taxani for aw ñey, muur a koy maye.",
  "gonte": "'gonte",
  "goŋeet-goŋeeti": "'goŋeet-goŋeeti",
  "goo": "Bëgge bu la xañulee, booba bëggee goo.",
  "góob": "Déegug jànj du tee bare dugub. (,) Déegub jànj du tee góob. (,)",
  "góobaani": "'góobaani",
  "góobaat": "'góobaat",
  "góobagul": "'góobagul",
  "góobaguloon": "'góobaguloon",
  "góobal": "'góobal",
  "góobe": ". Ku guux peterol di wólub taal, loo ca góobe gar ko.  . Ku iñaanul ne Yàllaak diw.",
