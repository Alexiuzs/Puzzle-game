  "yemukaay": "'yemukaay",
  "yemukaayu": "Defal boppam 'yemukaay' walla ne ci (Reflexive/Action on self).",
  "yemul": "Aawo buuru këram ; Ginaar wéete wolandoom ; Gëse benn tànk.  .\tGinaarug jàmbur ku mu yóbbu poliis, danga yemul ci “kes !”",
  "yemuma": "'yemuma",
  "yemunu": "Defal boppam 'yemun' walla ne ci (Reflexive/Action on self).",
  "yemuñu": "Defal boppam 'yemuñ' walla ne ci (Reflexive/Action on self).",
  "yemuwel": "'yemuwel",
  "yen": "Am na ku la ne “ma yen la” ; booba, la ca ndab la la bëgga gis. (,) Am na ku la ne ma yen la, tey sa ndab la bëgg séet.",
  "yenaat": "'yenaat",
  "yenam": "'yenam",
  "yendoo": ". Kerug caxat, bu ca mbooloo yendoo garab ga mu law a tax.  . Kettet buy la jig te buy daanuy toj.",
  "yendu": "Defal boppam 'yend' walla ne ci (Reflexive/Action on self).",
  "yëndulu": "Defal boppam 'yëndul' walla ne ci (Reflexive/Action on self).",
  "yene": "'yene",
  "yenee": "'yenee",
  "yeneen": "'yeneen",
  "yeneeni": "'yeneeni",
  "yengal": "'yengal",
  "yëngal": ". Ku yónni say noon di nga leen yàkkamti.  . Kuddoo ñeme gar ba ñu di ko ràcceeb laax.  . Kuddu gu mag ay yëngal dëxin.",
  "yëngalati": "'yëngalati",
