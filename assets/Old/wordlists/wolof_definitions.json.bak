  "jibalee": "'jibalee",
  "jibalul": "'jibalul",
  "jibandoo": "'jibandoo",
  "jibati": "'jibati",
  "jibe": "Bu nu demee ba ca cippaa ndaw ja, yuux dina jibe fu ñu ko foogewul.",
  "jibee": "'jibee",
  "jibeeti": "'jibeeti",
  "jiboon": "'jiboon",
  "jibu": "'jibu",
  "jibul": "'jibul",
  "jie": "'jie",
  "jif": "'jif",
  "jig": ". Kerug caxat, bu ca mbooloo yendoo garab ga mu law a tax.  . Kettet buy la jig te buy daanuy toj.",
  "jigée": "'jigée",
  "jigéen": "Àddina jigéen la, ju fu mu tollu, mu ngi ëmb te kenn xamul lu muy jur.",
  "jigéenam": "'jigéenam",
  "jigéeni": "'jigéeni",
  "jigéenu": "Defal boppam 'jigéen' walla ne ci (Reflexive/Action on self).",
  "jigéenub": "'jigéenub",
  "jii": "'jii",
  "jiin": ".\tGéwal, su reppee cib xare, lu mu jiin xeeb ko. (,,) .\tGinaar ak i nenam yépp, boroom ginaar a moom. (,) Ginaar ak i nenam, lépp boroom a ko moom. (,)",
  "jiiñ": "Deñcin wu ñaaw moo gën jiiñ sab xarit.",
  "jiinaat": "'jiinaat",
  "jiinul": "'jiinul",
  "jiiñul": "'jiiñul",
  "jiit": "Fu jàmm yendu, waay a fa xam lu mu waxul.  .\tFu la jiit màtt, mu raay-raayi.",
  "jiital": ".\tKenn du jiital kilifa, ba noppi di ko fakktal.  .\tKenn du ma jam-naani.",
  "jiitale": "'jiitale",
  "jiitalee": "'jiitalee",
  "jiitalleen": "'jiitalleen",
  "jiitam": "'jiitam",
  "jiite": "Gumba du jiite yoon. (,,,) Gumba du jiiteew yoon. (,) Gumba du jiitew yoon. (,) Gumba du jiite aw yoon",
  "jiitee": "'jiitee",
