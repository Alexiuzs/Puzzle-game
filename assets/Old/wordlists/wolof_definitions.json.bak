  "suseen": "'suseen",
  "sut": ".\tKenn bëggul ku la sut ba mu des sa doom ja nga jur.  .\tKenn ci ñoom warul féete sa moroom gannaaw.  .\tKenn du boole say nen yépp ci genn leket.",
  "sutaate": "'sutaate",
  "sute": ". Lu dagg sute xaaxaam ba di ko sekki ?  . Lu damm ndigg ay dóoxaluw taat.",
  "sutu": "'sutu",
  "sutul": "Dagg, sutul xaaxaam lu mu koy sekkee.",
  "sutura": "Bu mag amee sutura moo ko may boppam.",
  "suturaal": "'suturaal",
  "suturaam": "'suturaam",
  "suturas": "'suturas",
  "suturlu": "Defal boppam 'suturl' walla ne ci (Reflexive/Action on self).",
  "suturlujee": "'suturlujee",
  "suturluji": "'suturluji",
  "suub": "Du man doõõ, bokkuma caa ko gën.  .\tDu xamum nganj, yàgg a suub la.",
  "suude": "'suude",
  "suuf": "Asamaan lu mu taw-taw suuf àttan ko.",
  "suuf-a-suuf": "'suuf-a-suuf",
  "suuf—xeet": "'suuf—xeet",
  "suufam": "Bëñ bu weex tàll, te deret ju ñuul kukk lal ko.  Bëñ de na ree, wandey deret anga ca suufam.  Bëñ weex na, nde deret a ko ronu.",
  "suufas": "'suufas",
  "suufasuuf": "'suufasuuf",
  "suufe": "'suufe",
  "suufee": "'suufee",
  "suufeel": "'suufeel",
  "suufeelal": "'suufeelal",
  "suufeelee": "'suufeelee",
  "suufi": "'suufi",
  "suufoo": "'suufoo",
  "suufu": "Defal boppam 'suuf' walla ne ci (Reflexive/Action on self).",
  "suufukat": "Ki di def walla ki sàkk 'suufu' (Someone who does...).",
  "suukar": "Bul diw suukar ci sama yaram, bàyyi maak sànqaleñ yi.",
  "suul": "Bu fukk dee gas, fukk di suul, pënd ay bari waaye pax du fa am. (,,,,,,,)",
  "suule": "Jëkka laye di tax nga ey.  .\tJël bu kii suule bu ki.",
  "suuli": "'suuli",
  "suuloo": "'suuloo",
  "suulu": "Defal boppam 'suul' walla ne ci (Reflexive/Action on self).",
  "suur": "Biir du suur, xel ay suur.",
  "suural": "'suural",
  "suure": ".\tDund gu jeexagul, weeru koor la : juubu weesoogu ca. (,,) .\tDuñu lekkloo nit su suure.",
  "suuroo": ". Saxaarus laax yáqul gëti mage yàgg na koo suuroo.",
  "suuru": "Defal boppam 'suur' walla ne ci (Reflexive/Action on self).",
  "suurukaay": "'suurukaay",
  "suurukaayi": "'suurukaayi",
  "suurul": ". Ngësëm wacce wu ma dama ñor tabbi.  . Ngooxi mbott du tee gaynde naan cib déeg.  . Ngor moo di lekk suurul, mu jóg.",
  "suuruleen": "'suuruleen",
  "suuruñu": "Defal boppam 'suuruñ' walla ne ci (Reflexive/Action on self).",
  "suux": ". Su ñu nee : “na xob yépp yëngu”, paftan taxul ñuy wax.  . Su picc geddee ab déeg, dafa ñal ag suux. (,)",
  "suuxa": "'suuxa",
  "suuxaat": "'suuxaat",
  "suuxal": "'suuxal",
  "suuxam": "'suuxam",
  "suuxat": "'suuxat",
  "suuxate": "'suuxate",
  "suuxati": "'suuxati",
  "suuxatu": "Defal boppam 'suuxat' walla ne ci (Reflexive/Action on self).",
  "suuxatul": "'suuxatul",
  "suuxi": "'suuxi",
  "suuxu": "Defal boppam 'suux' walla ne ci (Reflexive/Action on self).",
  "suwa": "'suwa",
  "suwaa": "'suwaa",
  "suweŋ": "'suweŋ",
  "suy": "Mburu su amoon gàllaaj gu muy digle suy dem ci taal ba takk ko.  . Mbuus deful lu gën pepp.",
  "suyal": "Boo nee laax bi tàng na, mu ne mbott suyal xorom.",
  "symboles": "'symboles",
  "taa": "Àddina, ndoxum joor la ; buy taa, mu ngay õiis (,)",
  "taa-taa": "'taa-taa",
  "taaaru": "Defal boppam 'taaar' walla ne ci (Reflexive/Action on self).",
