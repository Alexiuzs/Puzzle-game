  "ñawoona": "'ñawoona",
  "nawul": "'nawul",
  "nawum": "'nawum",
  "nax": "Caga, benn yoon la ñu koy nax.",
  "ñax": ". Lekk ñax mu wow, aste lekk ngooñ ak dugub, dina làpploo fas.  . Lëkkaayu Yàlla, xalangu du ko dindi. (,,)",
  "naxante": "'naxante",
  "naxat": "'naxat",
  "naxati": "'naxati",
  "naxe": ". Naxe, ku ca am mbubb, am ca tubéy, mbaxana të la ca. (,) Kuy nax may mbubb, tubëy ja të la.",
  "naxee": "'naxee",
  "naxekaay": "Àddina këru naxekaay la.",
  "naxekat": "Ki di def walla ki sàkk 'naxe' (Someone who does...).",
