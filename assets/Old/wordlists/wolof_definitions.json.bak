  "njëkkleen": "'njëkkleen",
  "njëkkleena": "'njëkkleena",
  "njëkkoon": "'njëkkoon",
  "njëkkoona": "'njëkkoona",
  "njekku": "Defal boppam 'njekk' walla ne ci (Reflexive/Action on self).",
  "njekkug": "'njekkug",
  "njëkkula": "'njëkkula",
  "njël": ".\tFa ñuy tëgge ab xàndoor, deesu fa ñaani njël ; fa ñu koy bey lañu koy ñaane. (,)",
  "njëlal": "'njëlal",
  "njëlam": ".  Lu cuuj tuut-tuut gàddu njëlam.  .  Lu daay tàkk-tàkk bàyyi fa kuréel. (,)",
