  "yeni": "'yeni",
  "yenn": "'yenn",
  "yenneeku": "Defal boppam 'yenneek' walla ne ci (Reflexive/Action on self).",
  "yenni": "“Jàppal, ma yenni la”, du sawar laa yenni, waaye bëgga xam la nga yenu la.",
  "yennikoo": "'yennikoo",
  "yenniku": "Defal boppam 'yennik' walla ne ci (Reflexive/Action on self).",
  "yenook": "'yenook",
  "yentem": "'yentem",
  "yenu": "Bët du yenu, waaye xam na lu bopp àttan. (,,,,,,,,,) Bët du yenu, waaye xam na lu bopp antan.",
  "yenub": "'yenub",
  "yenukat": "Ki di def walla ki sàkk 'yenu' (Someone who does...).",
  "yenul": ". Yen bi la Yàlla yenul, bala nga sonn, yow mi ko yenu, ñi lay seetaan ñooy jëkka sonn.",
  "yenule": "'yenule",
  "yenuwaale": "'yenuwaale",
  "yépp": ".\tDugal ginaar ci ngunu laa mën, waaye xawma fu geen gay féetee.  .\tDukk-dukk ak yoll-yoll, yépp ci xél yi la, waaye wégét ay seen baay.  .\tDuma bëgg lu la neex ba ne la Yàllaa ngi lay nuyu. (,)",
  "yéppn": "'yéppn",
  "yér": "'yér",
  "yër": "Balaa ginaar a duggati ci ngunu, yër ko.",
  "yeraange": "'yeraange",
  "yëral": "'yëral",
  "yerax": "'yerax",
  "yére": "Boroom yére yu weex war naa moytu boroom xàndig tiir.",
  "yëre": "Baay, wékkukaayu yëre la, buy dem yëre bi ci gën lay sol.",
  "yeredd": "'yeredd",
  "yéreek": "'yéreek",
  "yéreeki": "'yéreeki",
  "yéreem": "'yéreem",
  "yërëm": ". Koo jiitu ca mëninam mën ko.  . Koo jurul doo ko yërëm.",
  "yërëmal": "'yërëmal",
  "yërëmati": "'yërëmati",
  "yërëme": "'yërëme",
  "yërëmee": "'yërëmee",
  "yërëmoo": "'yërëmoo",
  "yërëmtalu": "Defal boppam 'yërëmtal' walla ne ci (Reflexive/Action on self).",
  "yërëmu": "Defal boppam 'yërëm' walla ne ci (Reflexive/Action on self).",
  "yërëmul": "'yërëmul",
  "yërëmuñu": "Defal boppam 'yërëmuñ' walla ne ci (Reflexive/Action on self).",
  "yérey": ". Ku sol yérey yu jafe, léegi anga sol sagar.",
  "yëri": "'yëri",
  "yërmande": "Yenukatu xëddéen dañuy yëgoo.  . Yëréet kësëõ, toq-toq yàgg fi rekk.  . Yërmande day wàññi doole.",
  "yërmandee": "'yërmandee",
  "yërmandeek": "'yërmandeek",
  "yërmandeem": "'yërmandeem",
  "yërmandey": "'yërmandey",
  "yërndu": "Defal boppam 'yërnd' walla ne ci (Reflexive/Action on self).",
  "yes": "'yes",
  "yësal": ". La àllaaxira di am jàmm yépp, Kumbaak Sàmba fa demul woon.  . La boroom géléem bëgg ci digóorug meer, yësal a ko koy may.  . La jarag am di yuux, su ko néew amoon jël. (,)",
  "yet": "Dangay jafandu ci gittax, ba ba ngay am yet.  Jàppal ci gittax gi ba keroog ba ngay am yet.",
  "yetam": "'yetam",
  "yetet": "'yetet",
  "yeti": "'yeti",
  "yett": "Baroom jur ci sa tool taxul nga yett giir.",
  "yettyatt": "'yettyatt",
  "yetu": "'yetu",
  "yetur": "'yetur",
  "yéwén": ". Yéwén : ci sa alal.  . Yóbbante àq la.",
  "yéwéne": "'yéwéne",
  "yéwénee": "'yéwénee",
  "yewus": "'yewus",
  "yewwi": ".\tGan du yewwi bëy. (,,,) Gan du yewwiy béy. (,)",
  "yewwoo": "'yewwoo",
  "yewwooti": "'yewwooti",
  "yewwu": "Defal boppam 'yeww' walla ne ci (Reflexive/Action on self).",
