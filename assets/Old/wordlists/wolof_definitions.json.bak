  "jiituleen": "'jiituleen",
  "jiitusi": "'jiitusi",
  "jikat": "Ki di def walla ki sàkk 'ji' (Someone who does...).",
  "jikko": "Bokk meen, taxul bokk jikko.",
  "jikkoo": ". Ñaaw jikko, rafet jikkoo ko gën.  Rafet jikko moo gën jikko ju bon.",
  "jikkook": ".\tJikko ak boroom : pax. (,) Jikkook boroom pax.  Jikkook boroom ba ci pax.",
  "jikkoom": "Cin bax na, waaye du jikkoom, matt a ko ca jóo.",
  "jikkowoo": "'jikkowoo",
  "jikkoy": "Bu raadu nee yàõõ baxaw bëgga booy, boo bëggee jot sa jikkoy baay sàccal ab jànqam.",
  "jimeet": "'jimeet",
  "jinigal": "'jinigal",
  "jinigalandoo": "'jinigalandoo",
  "jinigali": "'jinigali",
  "jinigalkat": "Ki di def walla ki sàkk 'jinigal' (Someone who does...).",
  "jinne": ".\tJël jinne tay ci njuuma.",
  "jippét": "'jippét",
  "jiq": "'jiq",
  "jirim": "Baayo bu fattalikoo soxor.  Jirim, bu fàttalikoo, soxar.",
  "jiw": ". Nàkk sol mbaam taxu koo yenuy goroõ.  . Nàkk wéy na jiw.",
