  "yiwiwaat": "'yiwiwaat",
  "yiwu": "Diggante xàcc ak dóor, yiwu Yàlla xaj na fa. (,)",
  "yiy": ".\tFa gaynde bóof ak i doomam, fa la mbedd yem.  .\tFa médd ya nekk, fa la tan yiy daje.",
  "yób": "'yób",
  "yobab": "'yobab",
  "yóbbaale": "Gaal, lu mu fees fees mëna yóbbaale benn bataaxal.  .\tGaalug dof du teer fu neex bokk ya. (,,)",
  "yóbbaaleel": "'yóbbaaleel",
