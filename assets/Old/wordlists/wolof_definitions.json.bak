  "dugalee": "'dugalee",
  "dugaleesul": "'dugaleesul",
  "dugg": "As gor dina dugg ciy naxam.",
  "duggaale": "'duggaale",
  "duggaan": "'duggaan",
  "duggaat": "'duggaat",
  "duggal": "'duggal",
  "duggalal": "'duggalal",
  "duggam": "'duggam",
  "duggandook": "'duggandook",
  "duggati": "Balaa ginaar a duggati ci ngunu, yër ko.",
  "dugge": ". Naan du dul faj mar, loo ca mos mu doy.  . Naanu rafetal soow mi nu dugge ko ja ba.  . Naar ba fa Gànnaar boppam la fa nekkal.",
  "duggee": "Doomu gaynde, bu dale ci gétt, jàmm jeex fa.  Gaynde bu duggee ci gétt, jàmm jeex na.",
  "duggeeka": "'duggeeka",
  "duggeji": "'duggeji",
  "duggewul": "'duggewul",
  "duggi": ". Mademmba Jóob Yatma Soog sëriñ bi ci Ñomre.  . Mag a moom xamam, su ko neexee làl ko toog.  . Mag ay duggi Ndóob.",
  "duggig": "'duggig",
  "dugglante": "'dugglante",
  "dugglanteek": "'dugglanteek",
  "duggleen": "'duggleen",
  "duggloo": "'duggloo",
  "duggoon": "'duggoon",
  "duggsee": "'duggsee",
  "duggsi": "'duggsi",
  "duggsil": "'duggsil",
  "duggsiwaat": "'duggsiwaat",
  "duggul": ". Néegub jargoñ la, du la fegalub sedd, du la fegalu tàngoor.  . Néegub ngor, kenn terewu ko, ku ci duggul ci yow la. (,) . Neenug neen, du rey bukki. (,)",
  "dugguleen": "'dugguleen",
  "dugguñu": "Defal boppam 'dugguñ' walla ne ci (Reflexive/Action on self).",
  "dugub": "Baax sabaarub dugub la ; fu ñu ko fabe, ay fepp ruus fa.",
  "dukkat": "Ki di def walla ki sàkk 'duk' (Someone who does...).",
  "dukkate": "'dukkate",
  "dul": "Bu dul wonteek benn kenn du ni ñaar",
  "dull": "'dull",
  "dum": ". Ñu bokk teen ñooy laxasooy goj. (,,,,) .  Ñu ma doon wax baay, juruma leen.  . Ñu may la lépp, nga jël lépp, dum xel. (,)",
  "duma": "Awma ginaar siiru sikk ma duma ci fekk.",
  "dumaa": "'dumaa",
  "dumaal": "Bu la bukki tooñee dumaal gaynde.",
  "dumab": "'dumab",
  "dumaji": "'dumaji",
  "dumalu": "Defal boppam 'dumal' walla ne ci (Reflexive/Action on self).",
  "dumat": "'dumat",
  "dumawaale": "'dumawaale",
  "dumawoon": "'dumawoon",
  "dumay": "'dumay",
  "dummóoyu": "Defal boppam 'dummóoy' walla ne ci (Reflexive/Action on self).",
  "dun": "'dun",
  "duñ": ".\tJëndle la fas wu yaa-biir te duñ(u) la ko gubleel.  .\tJigéen naka takkaayam day, la jikkoom day.  .\tJigéen ay jur lu ne.",
  "dund": "Àddina weeru koor la ; feek jant sowul, juubu du wees. (,) Dund gu jeexagul, weeru koor la : juubu weesoogu ca. (,,) Koor gu jant sowagul, juubu weesoogu ca.",
  "dund-jópp": "'dund-jópp",
  "dundaat": "'dundaat",
  "dundagum": "'dundagum",
  "dundal": "Balaa ngaa dundal ña ca mbedd ma nga dundal ña ca kër ga.",
  "dundalaat": "'dundalaat",
  "dundale": "'dundale",
  "dundam": "'dundam",
  "dundandoo": "'dundandoo",
  "dundati": "'dundati",
  "dundatul": "'dundatul",
  "dunde": ".\tGawar gu di dawal fasam, mbaxanaam wadd te jotu ko for ?  .\tGaynde bëggul mbuum, yàpp lay dunde. (,,,)",
  "dundee": "'dundee",
  "dundeji": "'dundeji",
  "dundey": "'dundey",
  "dundi": "'dundi",
  "dundin": "'dundin",
  "dundinu": "Defal boppam 'dundin' walla ne ci (Reflexive/Action on self).",
  "dundle": "'dundle",
  "dundloo": "'dundloo",
  "dundoon": "'dundoon",
  "dundu": "Defal boppam 'dund' walla ne ci (Reflexive/Action on self).",
  "dundub": "'dundub",
  "dundug": ".\tDund dundug wereyaan.",
  "dundul": "'dundul",
  "dung": ". Lu sax y dung naaw gannaaw bànjóoli.  . Lu surga sañadi, sañadi sañ ne : “suur naa”.  . Lu suur bajantu ba mu desub xaal.",
  "dungeen": "'dungeen",
  "duni": "'duni",
  "duññi": "'duññi",
  "duññiwul": "'duññiwul",
  "dunoo": "'dunoo",
  "dunq": "Kuy naaw, say dunq di ruus, fa nga jëm sorewul.  Kuy naaw sab geen di buubu, fa ngay dal du sori.",
  "dunqam": "'dunqam",
  "dunqi": "'dunqi",
  "dunu": "'dunu",
  "duñu": ".\tDund gu jeexagul, weeru koor la : juubu weesoogu ca. (,,) .\tDuñu lekkloo nit su suure.",
  "dunuy": "'dunuy",
  "duñuy": ". Laaxub daaw, bu ñ(u) ko dee nettali cafaay laa taxe.  Laaxub daaw, bu ñu koy nettali, cifaay laa tax. (,) Duñuy fàttaliku laaxu daaw/démb, cifaay ba tax.",
  "duŋŋ": "'duŋŋ",
