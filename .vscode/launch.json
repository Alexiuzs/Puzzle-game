{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Puzzle-game",
      "request": "launch",
      "type": "dart"
    },
    {
      "name": "Puzzle-game (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "Puzzle-game (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    },
    {
      "name": "prebuild:prebuilder",
      "type": "dart",
      "request": "launch",
      "program": "bin/prebuilder.dart",
      "cwd": "${workspaceFolder}/prebuild",
      "toolArgs": ["pub", "run", "prebuild:prebuilder", "all"]
    },
    {
      "name": "prebuild:prebuilder wordlist",
      "type": "dart",
      "request": "launch",
      "program": "bin/prebuilder.dart",
      "cwd": "${workspaceFolder}/prebuild",
      "toolArgs": ["pub", "run", "prebuild:prebuilder", "wordlist"]
    },
    {
      "name": "prebuild:prebuilder puzzle creation",
      "type": "dart",
      "request": "launch",
      "program": "bin/prebuilder.dart",
      "cwd": "${workspaceFolder}/prebuild",
      "toolArgs": ["pub", "run", "prebuild:prebuilder", "puzzles"]
    },
    {
      "name": "prebuild:test",
      "type": "dart",
      "request": "launch",
      "program": "bin/test.dart",
      "cwd": "${workspaceFolder}/prebuild",
      "toolArgs": ["pub", "run", "prebuild:test"]
    }
  ]
}
