  "version": "0.2.0",
  "configurations": [
    {
      "name": "Puzzle-game",
      "request": "launch",
      "type": "dart"
    },
    {
      "name": "Puzzle-game (profile mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile"
    },
    {
      "name": "Puzzle-game (release mode)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release"
    },
    {
      "name": "prebuild:prebuilder",
      "type": "dart",
      "request": "launch",
      "program": "lib/prebuilder.dart",
      "cwd": "${workspaceFolder}/prebuild",
      "toolArgs": ["pub", "run", "prebuild:prebuilder"]
    },{
      "name": "prebuild:test",
      "type": "dart",
      "request": "launch",
      "program": "lib/prebuilder.dart",
      "cwd": "${workspaceFolder}/prebuild",
      "toolArgs": ["pub", "run", "prebuild:prebuilder"]
    }
  ]
}
